{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "toc.yml",
          "index.md",
          "README.md"
        ]
      },
      {
        "files": [
          "api/toc.yml",
          "api/**/*.md"
        ]
      },
      {
        "files": [
          "docs/toc.yml",
          "docs/**/*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "LICENSE.txt"
        ]
      }
    ],
    "output": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "globalMetadata": {
      "_appTitle": "Invex.Extensions.Hosting",
      "_appName": "Invex.Extensions.Hosting",
      "_appFooter": "Useful utilities for Microsoft.Extensions.Hosting",
      "_enableSearch": true,
      "_disableContribution": false,
      "_disableToc": false,
      "_gitContribute": {
        "repo": "https://github.com/Invex-Games/hosting-extensions",
        "branch": "main"
      }
    },
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}


